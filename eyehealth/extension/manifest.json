{
  "manifest_version": 3,
  "name": "EyeGuard",
  "version": "1.2.0",
  "description": "AI Vision Health & Digital Correction System. Like Grammarly, but for your eyes.",

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "tabs",
    "scripting",
    "unlimitedStorage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/overlay.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "dist/main-world.js",
        "face_mesh/*.js",
        "face_mesh/*.wasm",
        "face_mesh/*.data",
        "face_mesh/*.binarypb",
        "icons/*.png",
        "assets/*",
        "vendor/mediapipe/*.js",
        "vendor/mediapipe/*.wasm",
        "vendor/mediapipe/*.data",
        "vendor/mediapipe/*.tflite"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
